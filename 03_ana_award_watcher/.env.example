# === LINE Messaging API ===
# LINE Developersコンソール > チャネル > Messaging API設定 で発行
LINE_CHANNEL_ACCESS_TOKEN=
# 通知を送りたい自分のLINEユーザーID（公式アカウントを友だち追加後、Webhookログや
# LINE Official Account Managerの「あなたの友だちリスト」テスト送信画面などから取得）
LINE_TO_USER_ID=

# === ANAマイレージクラブ アカウント（ローテーション用） ===
# お客様番号は10桁、パスワードはログイン用Webパスワード。
# 2〜3個まで登録可（ANA_ACCOUNT_2_*, ANA_ACCOUNT_3_* ...と番号を増やして追加）
ANA_ACCOUNT_1_CUSNUM=
ANA_ACCOUNT_1_PASSWORD=

ANA_ACCOUNT_2_CUSNUM=
ANA_ACCOUNT_2_PASSWORD=

ANA_ACCOUNT_3_CUSNUM=
ANA_ACCOUNT_3_PASSWORD=

# === チェック間隔（秒）。この範囲でランダムに待機時間を決める ===
CHECK_INTERVAL_MIN_SEC=900
CHECK_INTERVAL_MAX_SEC=1800

# === 1アカウントのセッションを使い続ける時間（時間）。超えたら別アカウントにローテーション ===
SESSION_MIN_HOURS=3
SESSION_MAX_HOURS=6

# === デバッグ・検証用 ===
# true にすると画面ありモード(headful)でブラウザを起動する（VPSではVNC等がないと使えない）
DEBUG_MODE=false
